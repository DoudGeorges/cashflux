# Required — Gemini API key for AI assistant
GEMINI_API_KEY=

# Required — Flask session secret
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional — Google Maps API key for map features
GOOGLE_MAPS_API_KEY=

# Optional — ElevenLabs API key for voice assistant
ELEVENLABS_API_KEY=

# Legacy fallback — alternative Gemini API key variable names
# GOOGLE_API_KEY=
# API=
